# ============================================
# InteractiveNovel - Environment Variables
# ============================================
# How to use:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Fill in your own API Key
#   3. Start the server:  cd server && node index.js
#
# You can also configure the API Key from the in-app "Settings" page after startup.
# ============================================

# LLM API Key (required)
# Supports Alibaba Cloud DashScope (Qwen) OpenAI-compatible mode
# Get one at: https://bailian.console.aliyun.com/cn-beijing?tab=model#/api-key
QWEN_API_KEY=your_api_key_here

# LLM API endpoint (optional, defaults to DashScope compatible mode)
# Any OpenAI-compatible endpoint works
QWEN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# Cover image generation model (optional, default: wan2.7-image)
IMAGE_MODEL=wan2.7-image

# Server port (optional, default: 3000)
PORT=3000
